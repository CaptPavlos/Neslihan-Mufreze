# Stripe — create products/prices in the Stripe Dashboard
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PRICE_KAPTANLIGA=price_...
NEXT_PUBLIC_STRIPE_PRICE_OFFSHORE=price_...

# Cal.com booking links (optional — placeholder defaults are used when unset)
NEXT_PUBLIC_CAL_COM_LINK_30=neslihanmufreze/30min
NEXT_PUBLIC_CAL_COM_LINK_60=neslihanmufreze/60min
NEXT_PUBLIC_CAL_COM_LINK_PKG=neslihanmufreze/mentorship

# Instagram Graph API — long-lived access token (60-day refresh) + Business Account ID
# When unset, the site falls back to the local /public/photos set with dummy counts.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
